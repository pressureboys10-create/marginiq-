# ── Jobber OAuth App Credentials ─────────────────────────────────────────────
# Create your app at: https://developer.getjobber.com
# Set your Redirect URI to: http://localhost:5000/api/jobber/callback  (dev)
#                        or: https://yourdomain.com/api/jobber/callback (prod)

JOBBER_CLIENT_ID=your_client_id_here
JOBBER_CLIENT_SECRET=your_client_secret_here

# The full URL of this app — used to build the OAuth redirect URI
# No trailing slash.
APP_URL=http://localhost:5000
